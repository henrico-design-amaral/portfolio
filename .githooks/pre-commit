#!/bin/sh
# Git pre-commit hook to prevent committing cache or OS/tool noise files

PATTERN='(^|/)(node_modules|dist|build|out|\.next|\.vercel|\.netlify|\.cache|\.parcel-cache|\.vite|\.turbo|coverage|\.lighthouseci|playwright-report|test-results)(/|$)|(\.log$|\.tsbuildinfo$|\.eslintcache$|\.stylelintcache$|Thumbs\.db$|\.DS_Store$|desktop\.ini$)'

# Get list of files staged for commit
STAGED_FILES=$(git diff --cached --name-only)

BLOCKED_FILES=""

for file in $STAGED_FILES; do
  if echo "$file" | grep -E -q "$PATTERN"; then
    BLOCKED_FILES="${BLOCKED_FILES}\n- ${file}"
  fi
done

if [ ! -z "$BLOCKED_FILES" ]; then
  echo -e "\033[31mError: You are trying to commit files that are blocked by cache-hygiene rules:\033[0m"
  echo -e "$BLOCKED_FILES"
  echo -e "\033[31mPlease remove these files from the staging area before committing.\033[0m"
  exit 1
fi

exit 0
