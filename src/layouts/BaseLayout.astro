---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  lang?: 'pt-BR' | 'en';
  locale?: 'pt' | 'en';
  isCase?: boolean;
}

const { title, description, lang = 'pt-BR', locale = 'pt', isCase = false } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const assetPath = (path: string) => `${basePath}${path.startsWith('/') ? path : `/${path}`}`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={assetPath('/favicon.svg')} type="image/svg+xml" />

  <!-- OG -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />

  <noscript>
    <style>
      .reveal { opacity: 1 !important; transform: none !important; }
    </style>
  </noscript>
</head>
<body>
  <a class="skip" href="#main">{locale === 'en' ? 'Skip to content' : 'Ir para o conteúdo'}</a>
  <Nav isCase={isCase} locale={locale} />

  <main id="main">
    <slot />
  </main>

  <Footer locale={locale} />

  <script>
    import '../scripts/motion.js';
  </script>
</body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/global.css';
  @import '../styles/motion.css';
</style>
