---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  entry: CollectionEntry<'cases'>;
  locale: 'pt' | 'en';
}

const { entry, locale } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = (value: string) => `${basePath}${value.startsWith('/') ? value : `/${value}`}`;
const casePrefix = locale === 'en' ? '/en/cases' : '/cases';
const labels = {
  pt: {
    project: 'Projeto · Contexto · Escopo',
    client: 'Cliente',
    sector: 'Setor',
    type: 'Tipo',
    role: 'Papel',
    scope: 'Escopo',
    platform: 'Plataforma',
    system: 'Sistema',
    domain: 'Domínio',
    users: 'Usuários',
    outcome: 'Resultado',
    evidence: 'Evidência',
    reading: 'Mapa da narrativa',
    readingLead: 'Cada case segue a mesma estrutura crítica, mas a tensão, as decisões e as restrições mudam por domínio.',
    impact: 'Impacto do projeto',
    impactTitle: 'Resultado publicado com lastro claro.',
    prev: '← Anterior',
    next: 'Próximo →',
  },
  en: {
    project: 'Project · Context · Scope',
    client: 'Client',
    sector: 'Sector',
    type: 'Type',
    role: 'Role',
    scope: 'Scope',
    platform: 'Platform',
    system: 'System',
    domain: 'Domain',
    users: 'Users',
    outcome: 'Outcome',
    evidence: 'Evidence',
    reading: 'Narrative map',
    readingLead: 'Each case follows the same critical structure, but tension, decisions, and constraints change by domain.',
    impact: 'Project impact',
    impactTitle: 'Published result with clear evidence.',
    prev: '← Previous',
    next: 'Next →',
  },
}[locale];

const readingSteps = locale === 'en'
  ? ['Context', 'Problem', 'Previous system', 'My role', 'Constraints', 'Design decision', 'Solution architecture', 'Main flow', 'Visual evidence', 'Impact', 'Limitations', 'Learning']
  : ['Contexto', 'Problema', 'Sistema anterior', 'Meu papel', 'Restrições', 'Decisão de design', 'Arquitetura da solução', 'Fluxo principal', 'Evidências visuais', 'Impacto', 'Limitações', 'Aprendizado'];
---

<BaseLayout
  title={`${data.title} · ${data.client} — Henrico Amaral`}
  description={data.description}
  lang={locale === 'en' ? 'en' : 'pt-BR'}
  locale={locale}
  isCase={true}
>
  <style>
    @import '../styles/home.css';
    @import '../styles/case.css';
  </style>

  <header class="case-hero" data-navdark>
    <div class="case-hero__img" style={`background-image:url('${path(data.heroImage)}')`}></div>
    <div class="case-hero__in" data-reveal="hero">
      <div class="case-hero__eyebrow mono"><span class="ln"></span>{String(data.order).padStart(2, '0')} · {data.sector}</div>
      <h1>{data.title}</h1>
      <span class="case-hero__client">{data.client}</span>
      <p class="case-hero__lead">{data.lead}</p>
    </div>
  </header>

  <section class="case-spec" aria-label={labels.project} data-reveal>
    <dl class="case-spec__grid">
      <div class="case-spec__cell"><dt>{labels.client}</dt><dd>{data.client}</dd></div>
      <div class="case-spec__cell"><dt>{labels.sector}</dt><dd>{data.sector}</dd></div>
      <div class="case-spec__cell"><dt>{labels.type}</dt><dd>{data.type}</dd></div>
      <div class="case-spec__cell"><dt>{labels.role}</dt><dd>{data.role}</dd></div>
      <div class="case-spec__cell"><dt>{labels.scope}</dt><dd>{data.scope}</dd></div>
      <div class="case-spec__cell"><dt>{labels.platform}</dt><dd>{data.platform}</dd></div>
    </dl>
  </section>

  <section class="overview" id="overview">
    <div class="wrap overview__grid">
      <div class="reveal">
        <div class="overview__kicker mono"><span class="ln"></span>{labels.project}</div>
        <h2>{data.outcome}</h2>
        <p>{data.lead}</p>
      </div>
      <dl class="subfacts reveal" data-d="1">
        <div class="subfacts__row"><dt>{labels.system}</dt><dd>{data.system}</dd></div>
        <div class="subfacts__row"><dt>{labels.domain}</dt><dd>{data.domain}</dd></div>
        <div class="subfacts__row"><dt>{labels.users}</dt><dd>{data.users}</dd></div>
        <div class="subfacts__row"><dt>{labels.outcome}</dt><dd>{data.outcome}</dd></div>
      </dl>
    </div>
  </section>

  <section class="case-reading" aria-label={labels.reading}>
    <div class="wrap case-reading__grid">
      <div class="case-reading__head reveal">
        <p class="mono">{labels.reading}</p>
        <h2>{labels.readingLead}</h2>
      </div>
      <ol class="case-reading__list reveal" data-d="1">
        {readingSteps.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{step}</strong>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <div class="case-content" id="case-story">
    <Content />
  </div>

  <section class="case-evidence" id="evidence">
    <div class="wrap case-evidence__grid">
      <p class="mono">{labels.evidence}</p>
      <p>{data.evidence}</p>
    </div>
  </section>

  <section class="case-impact" id="impact" data-navdark>
    <div class="case-impact__head reveal">
      <div class="k"><span class="ln"></span>{labels.impact}</div>
      <h2>{labels.impactTitle}</h2>
    </div>
    <div class="stat-grid reveal" data-d="1">
      {data.stats.map((s) => (
        <div class="stat">
          <div class="stat__n">{s.value}<small>{s.unit}</small></div>
          <p class="stat__d">{s.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="case-nav" aria-label={locale === 'en' ? 'Other cases' : 'Outros cases'}>
    <div class="case-nav__grid">
      {data.prevCase ? (
        <a href={path(`${casePrefix}/${data.prevCase.slug}/`)}>
          <span class="dir">{labels.prev}</span>
          <span class="nm">{data.prevCase.name}</span>
        </a>
      ) : <div></div>}
      {data.nextCase ? (
        <a href={path(`${casePrefix}/${data.nextCase.slug}/`)}>
          <span class="dir">{labels.next}</span>
          <span class="nm">{data.nextCase.name}</span>
        </a>
      ) : <div></div>}
    </div>
  </section>
</BaseLayout>

<style is:global>
  .case-reading {
    background: var(--paper);
    border-block: 1px solid var(--line);
    padding-block: clamp(42px, 6vh, 72px);
  }
  .case-reading__grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.55fr) minmax(0, 1fr);
    gap: clamp(32px, 6vw, 82px);
    align-items: start;
  }
  .case-reading__head .mono {
    color: var(--clay);
    margin-bottom: 14px;
  }
  .case-reading__head h2 {
    font-size: clamp(22px, 2.8vw, 34px);
    max-width: 18ch;
    color: var(--head);
  }
  .case-reading__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
  }
  .case-reading__list li {
    min-height: 82px;
    background: var(--cream);
    padding: 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 14px;
  }
  .case-reading__list span {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--clay);
  }
  .case-reading__list strong {
    font-size: 15px;
    line-height: 1.25;
    color: var(--ink);
  }
  .case-evidence {
    background: var(--paper);
    border-block: 1px solid var(--line);
    padding-block: clamp(34px, 5vh, 54px);
  }
  .case-evidence__grid {
    display: grid;
    grid-template-columns: minmax(160px, 0.28fr) minmax(0, 1fr);
    gap: clamp(22px, 4vw, 56px);
    align-items: baseline;
  }
  .case-evidence .mono {
    color: var(--clay);
  }
  .case-evidence p:not(.mono) {
    color: var(--ink-soft);
    max-width: 82ch;
    font-size: clamp(16px, 1.3vw, 18px);
    line-height: 1.58;
  }
  .case-content {
    background: var(--cream);
    padding-block: clamp(54px, 8vh, 104px);
    counter-reset: case-section;
  }
  .case-content > * {
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
    padding-inline: var(--gutter);
  }
  .case-content h2 {
    counter-increment: case-section;
    position: relative;
    font-size: clamp(28px, 3.2vw, 42px);
    color: var(--head);
    margin-top: clamp(58px, 8vh, 96px);
    margin-bottom: 24px;
    padding-top: 26px;
    border-top: 1px solid var(--line);
  }
  .case-content h2:first-child {
    margin-top: 0;
    border-top: 0;
    padding-top: 0;
  }
  .case-content h2::before {
    content: counter(case-section, decimal-leading-zero);
    display: block;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--clay);
    margin-bottom: 12px;
  }
  .case-content p {
    font-size: clamp(16.5px, 1.35vw, 18px);
    color: var(--ink-soft);
    line-height: 1.7;
    margin-bottom: 20px;
  }
  .case-content h2 + p {
    font-family: var(--f-display);
    color: var(--ink);
    font-size: clamp(19px, 1.9vw, 24px);
    line-height: 1.38;
    letter-spacing: -0.01em;
    max-width: 58ch;
  }
  .case-content ul {
    margin-block: 28px 34px;
    display: grid;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
  }
  .case-content li {
    list-style: none;
    margin: 0;
    background: var(--paper);
    padding: 15px 18px;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .case-content li::before {
    content: "";
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-right: 10px;
    transform: translateY(-1px);
    background: var(--gold);
    border-radius: 1px;
  }

  @media (max-width: 880px) {
    .case-reading__grid,
    .case-evidence__grid {
      grid-template-columns: 1fr;
    }
    .case-reading__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .case-reading__list {
      grid-template-columns: 1fr;
    }
    .case-content h2 + p {
      font-size: 18px;
    }
  }
</style>
