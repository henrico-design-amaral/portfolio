---
interface Props {
  locale?: 'pt' | 'en';
}

const { locale = 'pt' } = Astro.props;
const labels = {
  pt: {
    role: 'Senior Product Designer · Infraestrutura de decisão',
    line1: 'Pense simples.',
    line2: 'Faça melhor.',
    line3: 'Torne-se inevitável.',
    ecosystem: 'henrico.works · ecossistema completo',
    top: '↑ Voltar ao topo',
  },
  en: {
    role: 'Senior Product Designer · Decision infrastructure',
    line1: 'Think simple.',
    line2: 'Make it better.',
    line3: 'Become inevitable.',
    ecosystem: 'henrico.works · full ecosystem',
    top: '↑ Back to top',
  },
}[locale];
---

<footer class="footer" data-navdark>
  <div class="wrap">
    <div class="footer__top">
      <div class="footer__id">
        <div class="mono-mark">HA</div>
        <div>
          <div class="nm">Henrico Amaral</div>
          <div class="rl">{labels.role}</div>
        </div>
      </div>
      <p class="manifesto">{labels.line1}<br />{labels.line2}<br /><em>{labels.line3}</em></p>
    </div>
    <div class="footer__eco">
      <a href="https://henrico.works" target="_blank" rel="noopener">
        <span class="footer__eco-dot"></span>
        {labels.ecosystem}
      </a>
    </div>
    <div class="footer__bar">
      <span>Henrico Amaral · Product Designer · <span id="year">2026</span></span>
      <a href="#main">{labels.top}</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--cocoa);
    padding-block: clamp(60px, 8vh, 100px) 36px;
    position: relative;
    overflow: hidden;
  }
  .footer::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--rust), var(--gold), var(--rust));
  }
  .footer__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }
  .footer__id {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .mono-mark {
    width: 48px;
    height: 48px;
    border: 1px solid var(--line-dark);
    display: grid;
    place-items: center;
    font-family: var(--f-display);
    font-weight: 600;
    font-size: 18px;
    color: var(--gold-soft);
    border-radius: 6px;
  }
  .footer__id .nm {
    font-family: var(--f-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--on-dark);
  }
  .footer__id .rl {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--on-dark-faint);
    margin-top: 4px;
  }
  .manifesto {
    font-family: var(--f-display);
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 600;
    color: var(--on-dark);
    line-height: 1.05;
    letter-spacing: -0.02em;
    text-align: right;
    max-width: 14ch;
    text-wrap: balance;
  }
  .manifesto em { font-style: normal; color: var(--gold-soft); }
  .footer__eco {
    margin-top: clamp(30px, 4vh, 50px);
    padding-block: 20px;
    border-top: 1px solid var(--line-dark);
    border-bottom: 1px solid var(--line-dark);
  }
  .footer__eco a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--on-dark-soft);
    transition: color 0.25s;
  }
  .footer__eco a:hover { color: var(--gold-soft); }
  .footer__eco-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
  }
  .footer__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: clamp(20px, 3vh, 40px);
    padding-top: 24px;
    color: var(--on-dark-faint);
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    flex-wrap: wrap;
    gap: 14px;
  }
  .footer__bar a {
    color: var(--on-dark-soft);
    display: inline-flex;
    align-items: center;
    gap: 7px;
    transition: color 0.25s;
  }
  .footer__bar a:hover { color: var(--gold-soft); }

  @media (max-width: 680px) {
    .manifesto { text-align: left; font-size: 30px; }
    .footer__top { flex-direction: column; }
  }
</style>
